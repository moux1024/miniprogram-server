# ========== 服务 ==========
PORT=3000
NODE_ENV=development

# HTTPS 证书（可选，默认 /etc/cloudflare/ 下的 cert.pem、key.pem）
# SSL_CERT_DIR=/etc/cloudflare
# SSL_CERT=/etc/cloudflare/cert.pem
# SSL_KEY=/etc/cloudflare/key.pem

# ========== 数据库 MySQL ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=wechat_mall

# ========== 微信小程序 ==========
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_app_secret

# ========== JWT 鉴权 ==========
JWT_SECRET=your_random_secret_key_change_in_production

# ========== 邮件（发验证码等，可选） ==========
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@example.com
EMAIL_SMTP_PASSWORD=your_email_password
EMAIL_FROM=your_email@example.com
